# --- WeLockin backend environment ---

# MongoDB connection string. Prisma's MongoDB provider requires a replica set;
# MongoDB Atlas (mongodb+srv) provides one by default. Include the database name.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/welockin?retryWrites=true&w=majority"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me"

# How long issued tokens stay valid (e.g. 30d, 12h, 3600). Optional; defaults to 30d.
JWT_EXPIRES_IN="30d"

# HTTP port the server listens on.
PORT=8787

# CORS allow-list. Use * to allow any origin, or a comma-separated list of origins.
CORS_ORIGIN=*

# Sign in with Apple: the iOS app bundle id the identityToken's `aud` must match.
# Used by POST /api/auth/apple to verify tokens. Must match apps/mobile.
APPLE_BUNDLE_ID="in.welock.mobile"

# --- Admin console (POST /api/admin/login) ---
# Credentials the admin web app authenticates with. Set a strong password in
# production. Admin login is DISABLED while ADMIN_PASSWORD is empty.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""

# Separate signing secret for admin tokens (falls back to JWT_SECRET if unset).
ADMIN_JWT_SECRET="change-me-too"
# How long an admin session token stays valid. Optional; defaults to 12h.
ADMIN_JWT_EXPIRES_IN="12h"

# A live session with no heartbeat for longer than this (seconds) is treated as
# ended. Default 660 = two missed 5-min beats + grace.
LIVE_SESSION_STALE_SECONDS=660

# --- Resend (transactional email — addiction-protection partner OTP) ---
# API key from resend.com (starts with re_). Email is a no-op while empty.
RESEND_API_KEY=""
# Verified sender. The DOMAIN must be verified in your Resend account.
# For a quick test you can use: "WeLockin <onboarding@resend.dev>"
RESEND_FROM="WeLockin <protection@welock.in>"
