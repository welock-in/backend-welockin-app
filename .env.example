# --- WeLockin backend environment ---

# MongoDB connection string. Prisma's MongoDB provider requires a replica set;
# MongoDB Atlas (mongodb+srv) provides one by default. Include the database name.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/welockin?retryWrites=true&w=majority"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me"

# How long issued tokens stay valid (e.g. 30d, 12h, 3600). Optional; defaults to 30d.
JWT_EXPIRES_IN="30d"

# HTTP port the server listens on.
PORT=8787

# CORS allow-list. Use * to allow any origin, or a comma-separated list of origins.
CORS_ORIGIN=*

# Sign in with Apple: the iOS app bundle id the identityToken's `aud` must match.
# Used by POST /api/auth/apple to verify tokens. Must match apps/mobile.
APPLE_BUNDLE_ID="in.welock.mobile"
