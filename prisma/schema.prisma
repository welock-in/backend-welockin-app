// WeLockin backend — Prisma schema (MongoDB provider).
//
// NOTE: Prisma's MongoDB connector requires a replica set. MongoDB Atlas
// provisions one by default (even on the free M0 tier), so no extra setup is
// needed there. A bare local `mongod` will NOT work unless started as a
// replica set.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev. The rhel targets cover the Vercel/AWS Lambda
  // runtime: Node 20+ (Amazon Linux 2023) uses openssl-3.0.x, Node 18
  // (Amazon Linux 2) uses openssl-1.0.x. Bundling both means the client works
  // regardless of the Node version Vercel picks.
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  // Apple supplies a verified real or private-relay email on first consent.
  // Keeping this required preserves the existing PC contract and avoids the
  // single-null limitation of a MongoDB unique index.
  email        String    @unique
  passwordHash String?
  // Password registrations are unverified until an email-verification flow is
  // completed. Apple users are created with a verified token email.
  emailVerified Boolean? @default(false)
  plan         String    @default("trial")
  trialEndsAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  devices       Device[]
  focusEvents   FocusEvent[]
  snapshot      SyncSnapshot?
  authProviders AuthProvider[]
}

// Social / password login identities linked to a User (1-N). Lets one account
// be reached via Apple, Google, or email+password interchangeably.
model AuthProvider {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String // "apple" | "google" | "password"
  providerUid String // Apple `sub`, Google `sub`, or the user id for password
  createdAt   DateTime @default(now())

  @@unique([provider, providerUid])
  @@index([userId])
}

model Device {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  platform   String // OS: "windows" | "macos" | "android" | "ios" | "ipados"
  kind       String? // form factor: "desktop" | "phone" | "tablet"
  // Stable client-generated UUID = the real cross-platform identity key. Optional
  // for backward-compat: old clients that only send `name` keep working. New
  // identities use a deterministic Mongo _id, so concurrent heartbeats converge
  // without requiring a nullable unique index.
  deviceId   String?
  model      String?
  osVersion  String?
  appVersion String?
  pushToken  String? // APNs token (mobile push)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@unique([userId, name])
  @@index([userId, deviceId])
}

model SyncSnapshot {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @unique @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocklists Json
  sessions   Json
  // Weekly recurring schedule plan (client-defined SchedEvent[]). Optional so
  // snapshots created before this field existed still read back cleanly, and so
  // a client that never sends schedules (e.g. mobile) doesn't wipe them.
  schedules  Json?
  revision   Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model FocusEvent {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String?
  name           String
  startedAt      DateTime
  endedAt        DateTime
  plannedSeconds Int
  completed      Boolean
  hardLock       Boolean
  killedTotal    Int      @default(0)
  // Mobile / multi-platform additions (all optional → PC events unaffected).
  platform       String? // "ios" | "ipados" | "macos" | "windows"
  clientEventId  String? // idempotency key for offline replay
  // Optional during the first rollout so pre-existing Mongo documents that do
  // not contain the field remain readable. New writes always provide a boolean.
  emergencyUsed  Boolean? @default(false)
  createdAt      DateTime @default(now())

  // No nullable unique index is needed: events carrying a clientEventId use a
  // deterministic Mongo _id, making concurrent replay atomic at the DB level.
  @@index([userId])
  @@index([userId, startedAt])
  @@index([userId, clientEventId])
}
