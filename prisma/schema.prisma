// WeLockin backend — Prisma schema (MongoDB provider).
//
// NOTE: Prisma's MongoDB connector requires a replica set. MongoDB Atlas
// provisions one by default (even on the free M0 tier), so no extra setup is
// needed there. A bare local `mongod` will NOT work unless started as a
// replica set.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev. The rhel targets cover the Vercel/AWS Lambda
  // runtime: Node 20+ (Amazon Linux 2023) uses openssl-3.0.x, Node 18
  // (Amazon Linux 2) uses openssl-1.0.x. Bundling both means the client works
  // regardless of the Node version Vercel picks.
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  // Apple supplies a verified real or private-relay email on first consent.
  // Keeping this required preserves the existing PC contract and avoids the
  // single-null limitation of a MongoDB unique index.
  email        String    @unique
  passwordHash String?
  // Password registrations are unverified until an email-verification flow is
  // completed. Apple users are created with a verified token email.
  emailVerified Boolean? @default(false)
  plan         String    @default("trial")
  trialEndsAt  DateTime?
  // Admin gate for the feedback board (moderation, status changes). We gate on
  // this column, NOT an email allowlist: Sign in with Apple + Private Relay puts
  // an @privaterelay.appleid.com email in the JWT, so an email allowlist would
  // silently break. OPTIONAL on purpose: on MongoDB `@default` is a create-time
  // default only and `db push` never rewrites existing docs — a REQUIRED field
  // would make Prisma throw when reading any legacy user (locking out login).
  // Optional → legacy docs read back as null, and every check is `!user?.isAdmin`.
  isAdmin      Boolean?  @default(false)
  // Account moderation state, set from the admin console: "active" | "suspended".
  // Optional so documents written before this field existed still read cleanly.
  status       String?   @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  devices         Device[]
  focusEvents     FocusEvent[]
  snapshot        SyncSnapshot?
  authProviders   AuthProvider[]
  featureRequests FeatureRequest[] @relation("UserFeatureRequests")
  votes           Vote[]           @relation("UserVotes")
  liveSessions    LiveSession[]
  protectionLock  ProtectionLock?
  pushTokens      PushToken[]
}

// A focus session that is HAPPENING RIGHT NOW, reported by a client via
// `POST /api/sessions/heartbeat` roughly every 5 minutes while it runs (and once
// on start / on end). The admin console reads these to show live activity in
// near-real-time. One row per (user, device): a device has at most one live
// session, upserted on each beat and deleted when the session ends. A row whose
// `lastHeartbeatAt` is older than the staleness window is treated as ended
// (the client crashed / went offline without a clean stop).
model LiveSession {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stable client device id (e.g. "win-<MachineGuid>").
  deviceId      String
  // Client session id (the desktop's per-session id). A device runs UP TO TWO
  // sessions at once (a manual "Start Focus" + a scheduled one), so a device has
  // one LiveSession row PER session, not per device. Optional so rows written by
  // the earlier one-per-device version still read back (they expire quickly). The
  // row `id` is deterministic from (user, device, session).
  sessionId     String?
  deviceName    String?
  platform      String? // "windows" | "macos" | "android" | "ios" | "ipados"
  name          String // session title
  phase         String   @default("running") // "running" | "break"
  hardLock      Boolean  @default(false)
  totalSeconds  Int      @default(0)
  remainSeconds Int      @default(0)
  killedTotal   Int      @default(0)
  appsCount     Int      @default(0)
  sitesCount    Int      @default(0)
  originEventId String? // schedule block id that auto-started it, if any
  startedAt     DateTime
  endsAt        DateTime? // predicted end (now + remaining)
  // Admin "force end" signal: set true from the console; the client stops the
  // session (overriding a hard lock) on its next heartbeat and deletes the row.
  forceEnd      Boolean  @default(false)
  lastHeartbeatAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId, deviceId])
  @@index([lastHeartbeatAt])
}

// Social / password login identities linked to a User (1-N). Lets one account
// be reached via Apple, Google, or email+password interchangeably.
model AuthProvider {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String // "apple" | "google" | "password"
  providerUid String // Apple `sub`, Google `sub`, or the user id for password
  createdAt   DateTime @default(now())

  @@unique([provider, providerUid])
  @@index([userId])
}

model Device {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  platform   String // OS: "windows" | "macos" | "android" | "ios" | "ipados"
  kind       String? // form factor: "desktop" | "phone" | "tablet"
  // Stable client-generated UUID = the real cross-platform identity key. Optional
  // for backward-compat: old clients that only send `name` keep working. New
  // identities use a deterministic Mongo _id, so concurrent heartbeats converge
  // without requiring a nullable unique index.
  deviceId   String?
  model      String?
  osVersion  String?
  appVersion String?
  pushToken  String? // APNs token (mobile push)
  // Anti-abuse / one-active-phone-per-account (Part D). ALL optional on purpose:
  // on MongoDB a required field would make Prisma throw when reading legacy Device
  // docs that predate the column (breaking device registration). Optional → they
  // read back as null, and the post-push backfill sets sane values (status active,
  // kind by platform, boundAt=createdAt). `null` status is treated as "active".
  // (`kind` is declared above — form factor: "desktop" | "phone" | "tablet".)
  status        String?   @default("active") // "active" | "superseded" | "revoked"
  boundAt       DateTime?
  supersededAt  DateTime?
  lastRebindAt  DateTime?
  idfv          String? // Apple IDFV — WEAK correlation hint only (regenerates on reinstall)
  attestKeyId   String? // App Attest key id (base64)
  attestPubKey  Bytes? //  App Attest public key (raw/DER), set at key registration
  attestCounter Int?      @default(0) // strictly-increasing App Attest assertion counter (anti-replay)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  // NOTE: (userId, name) is intentionally NON-unique. Two iPhones report the same
  // UIDevice.name ("iPhone") to unentitled apps, and a takeover keeps the old row
  // (superseded) while binding the new phone — a unique(userId,name) would make the
  // new "iPhone" row collide and block takeover for the whole iOS base. Uniqueness
  // is enforced by the partial unique indexes (one active phone; one row per
  // (userId, deviceId)) created in scripts/device-migrate.ts.
  @@index([userId, name])
  @@index([userId])
  @@index([userId, deviceId])
  @@index([userId, status])
}

// Audit trail of one-active-phone handovers. Keyed by the stable client deviceId
// (a UUID string), not the Device row id. Drives the rebind cooldown ("last real
// transfer") and gives support a history. `first-bind` transfers are excluded
// from cooldown math.
model DeviceTransfer {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  fromDeviceId String? // previous active phone's client deviceId (null on first-bind)
  toDeviceId   String // new active phone's client deviceId
  reason       String // "takeover" | "first-bind" | "revoke"
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// Server-side break accounting (Part C/D). The mobile app enforces breaks locally
// & offline; this row is the authoritative record for the per-user daily budget.
// Over-budget breaks are recorded quarantined (server veto) without blocking the
// offline grant. Idempotent on (userId, clientBreakId).
model Break {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  deviceId        String?
  clientBreakId   String?
  durationSeconds Int
  startedAt       DateTime @default(now())
  endsAt          DateTime
  quarantined     Boolean? @default(false)
  createdAt       DateTime @default(now())

  @@index([userId, startedAt])
  @@index([userId, clientBreakId])
}

model SyncSnapshot {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @unique @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocklists Json
  sessions   Json
  // Weekly recurring schedule plan (client-defined SchedEvent[]). Optional so
  // snapshots created before this field existed still read back cleanly, and so
  // a client that never sends schedules (e.g. mobile) doesn't wipe them.
  schedules  Json?
  revision   Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model FocusEvent {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String?
  name           String
  startedAt      DateTime
  endedAt        DateTime
  plannedSeconds Int
  completed      Boolean
  hardLock       Boolean
  killedTotal    Int      @default(0)
  // Mobile / multi-platform additions (all optional → PC events unaffected).
  platform       String? // "ios" | "ipados" | "macos" | "windows"
  clientEventId  String? // idempotency key for offline replay
  // Optional during the first rollout so pre-existing Mongo documents that do
  // not contain the field remain readable. New writes always provide a boolean.
  emergencyUsed  Boolean? @default(false)
  // Anti-abuse (Part D): set true when the reporting deviceId does not resolve to
  // the user's active phone (kept for audit, excluded from stats/streaks/quotas).
  // Optional so legacy events read back cleanly; null/false both count.
  quarantined    Boolean? @default(false)
  createdAt      DateTime @default(now())

  // No nullable unique index is needed: events carrying a clientEventId use a
  // deterministic Mongo _id, making concurrent replay atomic at the DB level.
  @@index([userId])
  @@index([userId, startedAt])
  @@index([userId, clientEventId])
}

// ---------------------------------------------------------------------------
// Feedback / feature-request board (public, auth-gated, UGC — Apple 1.2 compliant
// via report + delete + auto-hide). All models below are NEW → purely additive.
// ---------------------------------------------------------------------------

enum FeatureRequestStatus {
  open
  planned
  in_progress
  done
  declined
}

model FeatureRequest {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  authorId     String               @db.ObjectId
  author       User                 @relation("UserFeatureRequests", fields: [authorId], references: [id], onDelete: Cascade)
  title        String
  body         String               @default("")
  status       FeatureRequestStatus @default(open)
  voteCount    Int                  @default(0) // denormalized; recomputed as count(votes) on every vote write
  commentCount Int                  @default(0) // reserved — comment routes are out of MVP scope
  hidden       Boolean              @default(false) // moderation: hidden rows never appear in GET /
  reportCount  Int                  @default(0)
  // Idempotency key for create retries (offline replay of the same POST). Every
  // FeatureRequest is created with one; the compound unique below makes a retried
  // POST return the existing row instead of inserting a duplicate. This is a NEW
  // model so every row has a non-null value — the @@unique is safe on `db push`.
  clientRequestId String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  votes   Vote[]
  reports FeatureReport[]

  @@unique([authorId, clientRequestId])
  @@index([authorId])
  @@index([status, voteCount])
  @@index([createdAt])
}

model Vote {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  featureRequestId String         @db.ObjectId
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  userId           String         @db.ObjectId
  user             User           @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  // One vote per user per request. Idempotency of add/remove is enforced in the
  // route (catch P2002 on add, deleteMany on remove) so the client never sees a
  // 409/500 on a double-tap.
  @@unique([featureRequestId, userId])
  @@index([userId])
}

model FeatureReport {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  featureRequestId String         @db.ObjectId
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  reporterId       String         @db.ObjectId
  reason           String
  createdAt        DateTime       @default(now())

  @@unique([featureRequestId, reporterId]) // one report per user per post
  @@index([featureRequestId])
}

// ---------------------------------------------------------------------------
// Addiction protection: a GLOBAL curated blocklist (admin-managed) + per-user
// lock state (partner OTP / dated). NEW → purely additive.
// ---------------------------------------------------------------------------

// One entry (a site or app) in the global curated addiction-protection list.
// Seeded from the app's bundled JSON, then admin-managed via the console; clients
// fetch the active set on launch (GET /api/addiction-protection). Collection is
// named "protection" in Mongo.
model ProtectionEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  category  String // "explicit" | "gambling" | ...
  kind      String // "site" | "app"
  value     String // normalized domain (host-only) or app id / exe name
  label     String? // display name
  platform  String?  @default("all") // "all" | "windows" | "macos" | "android" | "ios"
  active    Boolean  @default(true) // soft-disable without deleting
  source    String   @default("admin") // "seed" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, value]) // dedup + idempotent upsert
  @@index([category, active])
  @@map("protection")
}

// Per-user addiction-protection lock. `method` = "partner" (unlock needs a
// one-time code emailed to the partner via Resend) or "date" (no unlock before
// `lockedUntil`). The OTP is stored so the admin console can display it and
// support/override an unlock (a friction code, not a credential).
model ProtectionLock {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @unique @db.ObjectId
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  active         Boolean   @default(false)
  method         String    @default("partner") // "partner" | "date"
  categories     String[] // enabled categories, e.g. ["explicit","gambling"]
  partnerContact String? // partner email the OTP is sent to
  otp            String? // current one-time code (partner method)
  otpSentAt      DateTime?
  // Failed unlock attempts against the CURRENT otp. Capped so a user can't brute-
  // force the 6-digit code: past the cap the otp is invalidated (a new one must be
  // requested, re-involving the partner). Reset on every (re)send.
  otpAttempts    Int?      @default(0)
  lockedUntil    DateTime? // date method: no unlock before this
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("protection_locks")
}

// ---------------------------------------------------------------------------
// Push notifications: one row per push token owned by a user's device. NEW →
// purely additive. `@unique(token)` makes registration idempotent AND gives the
// receipt worker a natural key to prune tokens the Expo Push service reports as
// DeviceNotRegistered. This is the foundation (P0) of the notification system.
// ---------------------------------------------------------------------------
model PushToken {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The client deviceId this token belongs to (links to a Device row). Optional so
  // a token can be stored even before/without a registered Device row.
  deviceId       String?
  token          String    @unique // e.g. "ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]"
  platform       String? // "ios" | "ipados" | "android"
  tokenType      String    @default("expo") // "expo" | "apns" | "fcm"
  valid          Boolean   @default(true)
  disabledReason String? // set by the receipt worker, e.g. "DeviceNotRegistered"
  appVersion     String?
  failureCount   Int       @default(0)
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([userId, valid])
  @@map("push_tokens")
}

// One row per push sent to one device — the audit log + inbox source + receipt
// reconciliation target. No User back-relation (raw userId, like Break) → cleaned
// up explicitly in me.ts. NEW → purely additive (P1).
model NotificationDelivery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId // recipient (null for a token with no known owner)
  token     String? // the push token targeted
  title     String
  body      String
  data      Json?
  channel   String   @default("push")
  status    String   @default("queued") // "queued" | "sent" | "error" | "invalid"
  ticketId  String? // Expo ticket id (for later receipt polling)
  error     String? // Expo/transport error message when status="error"
  source    String   @default("admin") // "admin" | "rule:<event>"
  // Best-effort idempotency key (from a rule's dedupeKeyTemplate) so concurrent
  // first-beats of the same session don't double-notify the same user.
  dedupeKey String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([dedupeKey])
  @@map("notification_deliveries")
}

// ---------------------------------------------------------------------------
// Data-driven notification engine (P2). A TEMPLATE is the content (title/body/data
// with {{variables}}); a RULE binds an event to a template + audience + throttle,
// entirely in data — so new notifications are added from the admin with NO code.
// ---------------------------------------------------------------------------
model NotificationTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique // e.g. "pc_locked"
  title     String // supports {{variables}}
  body      String // supports {{variables}}
  data      Json? // deep-link payload template; string values support {{variables}}
  category  String   @default("system") // "cross_device" | "lifecycle" | "system" | "marketing" | "security"
  sound     String?  @default("default")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

model NotificationRule {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  event             String // "session.started"
  // Match against the event context, e.g. { "platform": { "$in": ["windows","macos"] } }.
  condition         Json     @default("{}")
  templateKey       String
  // e.g. { "mode": "sameUserOtherDevices", "excludeOrigin": true }.
  audience          Json
  dedupeKeyTemplate String? // e.g. "pc_locked:{{sessionId}}"
  enabled           Boolean  @default(true)
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([event, enabled])
  @@map("notification_rules")
}
